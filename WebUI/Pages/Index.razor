@page "/"

<PageTitle>拖拉机游戏</PageTitle>

<div class="welcome-container">
    <h1>🎴 拖拉机游戏</h1>
    <p>80分 · 单机AI对战</p>

    <div class="menu">
        <button class="menu-btn" @onclick="StartGame">开始游戏</button>
        <button class="menu-btn">规则说明</button>
        <button class="menu-btn">设置</button>
    </div>
</div>

<style>
    .welcome-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100vh;
        background: linear-gradient(135deg, #0D5C2F 0%, #1a8f4f 100%);
        color: white;
    }

    h1 {
        font-size: 48px;
        margin-bottom: 10px;
    }

    p {
        font-size: 20px;
        margin-bottom: 50px;
        opacity: 0.9;
    }

    .menu {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .menu-btn {
        padding: 15px 60px;
        font-size: 20px;
        background: rgba(255, 255, 255, 0.2);
        border: 2px solid white;
        border-radius: 12px;
        color: white;
        cursor: pointer;
        transition: all 0.3s;
        font-weight: bold;
    }

    .menu-btn:hover {
        background: rgba(255, 255, 255, 0.3);
        transform: scale(1.05);
    }
</style>

@code {
    [Inject]
    private NavigationManager? Navigation { get; set; }

    private void StartGame()
    {
        Navigation?.NavigateTo("/game");
    }
}
