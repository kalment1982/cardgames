    private RenderFragment RenderCard(string cardText, string mode, string? styleOverride = null) => builder =>
    {
        var cardImage = ResolveCardImage(cardText);
        if (!string.IsNullOrWhiteSpace(cardImage))
        {
            builder.OpenElement(0, "img");
            builder.AddAttribute(1, "class", $"review-card {mode}");
            builder.AddAttribute(2, "src", cardImage);
            builder.AddAttribute(3, "alt", cardText);
            builder.AddAttribute(4, "title", cardText);
            builder.AddAttribute(5, "style", styleOverride ?? BuildCardStyle(mode));
            builder.CloseElement();
            return;
        }

        builder.OpenElement(6, "span");
        builder.AddAttribute(7, "class", $"review-card-fallback {mode}");
        builder.AddAttribute(8, "title", cardText);
        builder.AddAttribute(9, "style", styleOverride ?? BuildCardStyle(mode));
        builder.AddContent(10, cardText);
        builder.CloseElement();
    };

    private static string BuildHandStackStyle(string orientation)
    {
        return orientation switch
        {
            "north" or "south" => "display:flex;align-items:flex-end;min-height:74px;padding:2px 6px 4px 10px;overflow:hidden;flex:1 1 auto;min-width:0;",
            "west" or "east" => "display:flex;flex-direction:column;justify-content:center;align-items:flex-start;gap:4px;padding:2px 0 2px 8px;overflow:hidden;flex:1 1 auto;min-height:0;min-width:0;",
            _ => "display:flex;align-items:center;"
        };
    }

    private static string BuildHandRowStyle()
    {
        return "display:flex;align-items:flex-end;min-width:0;";
    }

    private static string BuildCardStyle(string mode, string? orientation = null, int cardIndex = 0)
    {
        var baseStyle = mode switch
        {
            "hand" => "width:48px;height:70px;object-fit:contain;display:block;flex:0 0 auto;",
            "trick" => "width:46px;height:68px;object-fit:contain;display:block;flex:0 0 auto;",
            "mini" => "width:22px;height:33px;object-fit:contain;display:block;flex:0 0 auto;",
            "bottom" => "width:50px;height:74px;object-fit:contain;display:block;flex:0 0 auto;",
            _ => "width:24px;height:36px;object-fit:contain;display:block;flex:0 0 auto;"
        };

        if (mode == "hand" && cardIndex > 0)
        {
            if (orientation == "north" || orientation == "south")
                baseStyle += "margin-left:-24px;";
            else if (orientation == "west" || orientation == "east")
                baseStyle += "margin-left:-16px;";
        }

        return baseStyle;
    }

    private static string? ResolveCardImage(string? cardText)
    {
        if (string.IsNullOrWhiteSpace(cardText))
            return null;

        var text = cardText.Trim();
        if (text.Contains("大王", StringComparison.Ordinal))
            return "assets/playingcardshl/red_joker.png";
        if (text.Contains("小王", StringComparison.Ordinal))
            return "assets/playingcardshl/black_joker.png";

        string? suit = null;
        if (text.Contains('♠')) suit = "spades";
        else if (text.Contains('♥')) suit = "hearts";
        else if (text.Contains('♣')) suit = "clubs";
        else if (text.Contains('♦')) suit = "diamonds";

        if (string.IsNullOrWhiteSpace(suit))
            return null;

        var rankText = text
            .Replace("♠", string.Empty, StringComparison.Ordinal)
            .Replace("♥", string.Empty, StringComparison.Ordinal)
            .Replace("♣", string.Empty, StringComparison.Ordinal)
            .Replace("♦", string.Empty, StringComparison.Ordinal)
            .Trim()
            .ToUpperInvariant();

        var rank = rankText switch
        {
            "A" => "ace",
            "J" => "jack",
            "Q" => "queen",
            "K" => "king",
            "T" => "10",
            "10" => "10",
            "9" => "9",
            "8" => "8",
            "7" => "7",
            "6" => "6",
            "5" => "5",
            "4" => "4",
            "3" => "3",
            "2" => "2",
            _ => string.Empty
        };

        if (string.IsNullOrWhiteSpace(rank))
            return null;

        return $"assets/playingcardshl/{rank}_of_{suit}.png";
    }

    private async Task CopyIssueLocatorAsync()
    {
        if (CurrentTrick == null || Detail?.Summary == null)
            return;

        await JS.InvokeVoidAsync("navigator.clipboard.writeText", CurrentTrickUid);
    }

    private async Task CopyDecisionLocatorAsync(ReviewDecisionFrame decision)
    {
        var trick = CurrentTrick;
        var summary = Detail?.Summary;
        if (trick == null || summary == null)
            return;

        var roundToken = summary.RoundId ?? summary.SessionId;
        var trickToken = trick.TrickId ?? $"trick_{trick.TrickNo:D4}";
        var parts = new List<string>
        {
            $"问题定位: {roundToken}#{trickToken}",
            $"玩家: {DisplayPlayer(decision.PlayerIndex)}",
            $"AI: {DisplayText(decision.AiLine)}",
            $"阶段: {DisplayText(decision.Phase)}"
        };

        if (!string.IsNullOrWhiteSpace(decision.TurnId))
            parts.Add($"turn: {decision.TurnId}");

        if (!string.IsNullOrWhiteSpace(decision.Path))
            parts.Add($"path: {decision.Path}");

        var text = string.Join("\n", parts) + "\n现象:\n预期:\n备注:";
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    [JSInvokable]
    public Task HandleReviewHotkey(string key)
    {
        if (string.Equals(key, "ArrowLeft", StringComparison.Ordinal))
            PrevTrick();
        else if (string.Equals(key, "ArrowRight", StringComparison.Ordinal))
            NextTrick();

        StateHasChanged();
        return Task.CompletedTask;
    }

    private static int ParseTurnSequence(string? turnId, int playPosition)
    {
        if (!string.IsNullOrWhiteSpace(turnId))
        {
            var digits = new string(turnId.Where(char.IsDigit).ToArray());
            if (int.TryParse(digits, out var value))
                return value;
        }

        if (playPosition > 0)
            return playPosition;

        return int.MaxValue;
    }

    public async ValueTask DisposeAsync()
    {
        if (_keyboardRegistered)
        {
            try
            {
                await JS.InvokeVoidAsync("tractorReview.unregisterHotkeys");
            }
            catch
            {
                // ignore disposal failures during teardown
            }
        }

        _dotNetRef?.Dispose();
    }
