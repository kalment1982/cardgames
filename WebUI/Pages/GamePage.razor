    private bool CanHumanBidAnySuit()
    {
        if (game == null || game.State.Phase != GamePhase.Bidding)
            return false;

        return CanBid(Suit.Spade)
               || CanBid(Suit.Heart)
               || CanBid(Suit.Club)
               || CanBid(Suit.Diamond)
               || CanBid(Suit.Joker);
    }

    private static Suit ResolveFallbackTrumpSuit(Game game)
    {
        var levelRank = game.State.LevelRank;
        var dealer = game.State.DealerIndex;
        var suits = new[] { Suit.Spade, Suit.Heart, Suit.Club, Suit.Diamond };
        var score = suits.ToDictionary(s => s, _ => 0);

        // 优先考虑庄家手里的级牌花色，其次用全局级牌密度做兜底。
        var dealerLevelCards = game.State.PlayerHands[dealer]
            .Where(c => c.Rank == levelRank && c.Suit != Suit.Joker)
            .ToList();
        foreach (var card in dealerLevelCards)
            score[card.Suit] += 3;

        for (var i = 0; i < game.State.PlayerHands.Length; i++)
        {
            foreach (var card in game.State.PlayerHands[i].Where(c => c.Rank == levelRank && c.Suit != Suit.Joker))
                score[card.Suit] += 1;
        }

        return score
            .OrderByDescending(kv => kv.Value)
            .ThenBy(kv => kv.Key)
            .Select(kv => kv.Key)
            .FirstOrDefault();
    }

    private List<Card> GetPlayedCards(int playerIndex)
