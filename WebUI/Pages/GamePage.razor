    private async Task AutoFinalizeBid(bool onlyWhenNoHumanOption)
    {
        if (game == null || game.State.Phase != GamePhase.Bidding)
            return;

        var hasBid = game.CurrentBidSuit.HasValue;
        var humanCanBid = CanHumanBidAnySuit();
        if (onlyWhenNoHumanOption && humanCanBid && !hasBid)
            return;

        Suit finalSuit;
        bool forcedAuto;
        OperationResult finalize;
        if (hasBid)
        {
            finalSuit = game.CurrentBidSuit!.Value;
            forcedAuto = false;
            finalize = game.FinalizeTrumpEx();
        }
        else
        {
            finalSuit = ResolveFallbackTrumpSuit(game);
            forcedAuto = true;
            finalize = game.FinalizeTrumpEx(finalSuit);
        }

        if (!finalize.Success)
        {
            ShowMessage($"定主失败：{finalize.ReasonCode}");
            return;
        }

        await PushTestEventAsync(new
        {
            type = "trump_finalized",
            trumpSuit = finalSuit.ToString(),
            dealerIndex = game.State.DealerIndex,
            forced = forcedAuto
        });

        UpdateUI();
        var symbol = GameSessionService.GetSuitSymbol(finalSuit);
        if (game.State.DealerIndex == 0)
        {
            if (forcedAuto)
                ShowMessage($"已自动定主：{symbol}，请扣底（选择8张牌）");
            else
                ShowMessage($"定主完成：{symbol}，请扣底（选择8张牌）");
        }
        else
        {
            if (forcedAuto)
                ShowMessage($"已自动定主：{symbol}，庄家扣底中...");
            else
                ShowMessage($"定主完成：{symbol}，庄家扣底中...");
            await AIBuryBottom();
        }
    }

    private async Task AIBuryBottom()
    {
        if (game == null)
            return;

        int dealer = game.State.DealerIndex;
        var dealerHand = new List<Card>(game.State.PlayerHands[dealer]);

        // 使用训练好的Champion参数
        var championParams = ChampionLoader.LoadChampion();
        var aiPlayer = AIRuntimeSessionService.GetOrCreatePlayer(
            game,
            dealer,
            index => new AIPlayer(
                BuildCurrentConfig(),
                AIDifficulty.Hard,
                CurrentSeed + index + 1000,
                championParams,
                decisionLogger: AIDecisionLoggerFactory.Create(),
                ruleAIOptions: RuleAIOptionsProvider.Options));

        var logContext = GameSessionService.BuildAIDecisionLogContext(game, dealer);

        var cardsToBury = aiPlayer.BuryBottom(
            dealerHand,
            AIRole.Dealer,
            new List<Card>(game.BottomCardsSnapshot),
            logContext: logContext,
            defenderScore: game.State.DefenderScore,
            cardsLeftMin: dealerHand.Count);
        var buryResult = game.BuryBottomEx(cardsToBury);
        if (!buryResult.Success)
        {
            ShowMessage($"AI扣底失败：{buryResult.ReasonCode}");
            return;
        }

        await PushTestEventAsync(new
        {
            type = "bury_bottom",
            playerIndex = dealer,
            cards = SerializeCards(cardsToBury)
        });

        UpdateUI();
        ShowMessage("扣底完成，开始出牌");
        await ContinueAiTurnIfNeededAsync(deferUntilAfterDealingAnimation: true);
    }

    private async Task ContinueAiTurnIfNeededAsync(bool deferUntilAfterDealingAnimation = false)
    {
        if (game == null || game.State.Phase != GamePhase.Playing || game.State.CurrentPlayer == 0)
            return;

        if (deferUntilAfterDealingAnimation && _isDealingBiddingAnimation)
        {
            _pendingAiAutoPlayAfterDealing = true;
            return;
        }

        await Task.Delay(IsUiTestMode ? 1 : 300);

        if (game.State.Phase == GamePhase.Playing && game.State.CurrentPlayer != 0)
            await AIPlay();
    }

