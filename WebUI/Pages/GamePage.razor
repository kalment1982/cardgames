    private static List<Card> BuildBestBidAttempt(Game game, List<Card> levelCards)
    {
        for (var count = levelCards.Count; count >= 1; count--)
        {
            var attempt = levelCards.Take(count).ToList();
            if (game.CanBidTrumpEx(0, attempt).Success)
                return attempt;
        }

        return new List<Card>();
    }

    private string GetBidFailureMessage(Game game, string? reasonCode)
    {
        if (reasonCode == ReasonCodes.BidPriorityTooLow)
        {
            var player = game.CurrentBidPlayer;
            var suit = game.CurrentBidSuit;
            var levelCount = ResolveBidCardCount(suit, game.CurrentBidPriority);

            if (player >= 0)
                return $"亮主失败：当前{GetPlayerLabel(player)}已{FormatBidSummary(suit ?? Suit.Spade, levelCount)}";

            return "亮主失败：已有更高优先级亮主";
        }

        if (reasonCode == ReasonCodes.BidNotLevelCard)
            return "亮主失败：必须使用同花色级牌，或用一对大小王反无主";

        if (reasonCode == ReasonCodes.PhaseInvalid)
            return "亮主失败：当前阶段不可亮主";

        return $"亮主失败：{reasonCode ?? ReasonCodes.UnknownError}";
    }

    private string GetCardSizeClass(int cardCount)
    {
        // 根据牌数量返回不同的尺寸类
        if (cardCount <= 3)
