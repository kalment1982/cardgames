        else if (cardCount <= 8)
            return "size-medium";  // 4-8张：中尺寸 (55x82)
        else
            return "size-small";   // 9张以上：小尺寸 (45x67)
    }

    private static int ResolveBidCardCount(Suit? suit, int priority)
    {
        if (suit == Suit.Joker)
            return 2;

        return priority switch
        {
            0 => 1,
            1 => 2,
            _ => 3
        };
    }

