            return string.Empty;

        if (_historyTrick != null && _historyTrickNo > 0)
            return BuildTrickUid(game.RoundId, _historyTrickNo);

        if (game.State.Phase == GamePhase.Playing && game.CurrentTrick.Count > 0)
            return BuildTrickUid(game.RoundId, _trickNumber + 1);

        if (game.LastCompletedTrickNo > 0)
            return BuildTrickUid(game.RoundId, game.LastCompletedTrickNo);

        return string.Empty;
    }

    private string GetDisplayedTrickUidOrPlaceholder()
    {
        var uid = GetDisplayedTrickUid();
        return string.IsNullOrWhiteSpace(uid) ? "-" : uid;
    }

    private async Task CopyDisplayedTrickUid()
    {
        var uid = GetDisplayedTrickUid();
        if (string.IsNullOrWhiteSpace(uid))
        {
            ShowMessage("当前没有可复制的墩UID");
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", uid);
            ShowMessage($"已复制：{uid}");
        }
        catch
        {
            ShowMessage($"复制失败，请手动复制：{uid}");
        }
    }

    private static string BuildTrickUid(string roundId, int trickNo)
    {
        if (string.IsNullOrWhiteSpace(roundId) || trickNo <= 0)
            return string.Empty;

        return $"{roundId}/trick_{trickNo:D4}";
    }

    private string GetNormalizedPhase()
    {
        if (game == null)
            return "None";

        return game.State.Phase switch
        {
            GamePhase.Dealing => "Dealing",
            GamePhase.Bidding => "CallTrump",
            GamePhase.Burying => "BuryBottom",
            GamePhase.Playing => "PlayTricks",
            GamePhase.Finished => "Finished",
            _ => game.State.Phase.ToString()
        };
    }

}
