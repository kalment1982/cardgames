    private async Task RunDealingBiddingFlowAsync()
    {
        if (game == null || game.State.Phase != GamePhase.Bidding)
            return;

        var token = _dealingFlowCts?.Token ?? CancellationToken.None;
        _isDealingBiddingAnimation = true;
        _dealingRound = 0;
        _dealingActivePlayer = -1;
        _visibleHandCount = 0;
        _biddingAnimationText = "准备发牌...";
        await InvokeAsync(StateHasChanged);

        try
        {
            var levelRank = game.State.LevelRank;
            var visibleHands = new[]
            {
                new List<Card>(),
                new List<Card>(),
                new List<Card>(),
                new List<Card>()
            };

            string? lastBidInfo = null;
            var dealDelayMs = IsUiTestMode ? 1 : 130;
            var bidDelayMs = IsUiTestMode ? 1 : 240;
            var bottomCount = 0;

            while (!game.IsDealingComplete)
            {
                token.ThrowIfCancellationRequested();
                var dealResult = game.DealNextCardEx();
                if (!dealResult.Success)
                {
                    _biddingAnimationText = $"发牌失败：{dealResult.ReasonCode}";
                    await InvokeAsync(StateHasChanged);
                    return;
                }

                var step = game.LastDealStep;
                if (step == null)
                    continue;

                if (step.IsBottomCard)
                {
                    bottomCount++;
                    _dealingActivePlayer = -1;
                    _biddingAnimationText = $"底牌入底 {bottomCount}/8";
                    await InvokeAsync(StateHasChanged);
                    await Task.Delay(dealDelayMs, token);
                    continue;
                }

                var player = step.PlayerIndex;
                if (player < 0 || player >= visibleHands.Length)
                    continue;

                _dealingActivePlayer = player;
                _dealingRound = Math.Max(_dealingRound, step.PlayerCardCount);
                _biddingAnimationText = $"{GetPlayerLabel(player)} 摸牌（{step.PlayerCardCount}/25）";
                visibleHands[player].Add(step.Card);

                UpdateUI();
                _visibleHandCount = Math.Min(GetDealtVisibleCardCountForSouth(), 25);
                await InvokeAsync(StateHasChanged);
                await Task.Delay(dealDelayMs, token);

                var bidPlan = BuildBidAttemptFromVisibleCards(player, visibleHands[player], levelRank, step.PlayerCardCount - 1);
                var bidCards = bidPlan.Cards;
                if (bidCards.Count == 0)
                    continue;

                // 南家由玩家手动亮主，这里只驱动AI玩家自动竞叫。
                if (player == 0)
                    continue;

                if (!game.BidTrump(player, bidCards, bidPlan.Detail))
                    continue;

                var suit = bidCards[0].Suit;
                _lastBidPlayer = player;
                UpdateUI();
                lastBidInfo = $"P{player}{FormatBidSummary(suit, bidCards.Count)}";
                _biddingAnimationText = $"竞叫：{GetPlayerLabel(player)} {FormatBidActionText(suit)}";
                await InvokeAsync(StateHasChanged);
                await PushTestEventAsync(new
                {
                    type = "bid_trump",
                    playerIndex = player,
                    suit = suit.ToString(),
                    cards = SerializeCards(bidCards),
                    bid_reason = bidPlan.Detail != null && bidPlan.Detail.TryGetValue("bid_reason", out var bidReason) ? bidReason : null,
                    bid_reasons = bidPlan.Detail != null && bidPlan.Detail.TryGetValue("bid_reasons", out var bidReasons) ? bidReasons : null,
                    round_luck_p = bidPlan.Detail != null && bidPlan.Detail.TryGetValue("round_luck_p", out var roundLuck) ? roundLuck : null,
                    bid_stage = bidPlan.Detail != null && bidPlan.Detail.TryGetValue("bid_stage", out var bidStage) ? bidStage : null,
                    bid_used_luck = bidPlan.Detail != null && bidPlan.Detail.TryGetValue("bid_used_luck", out var usedLuck) ? usedLuck : null,
                    from_dealing = true,
                    deal_round = _dealingRound
                });
                await Task.Delay(bidDelayMs, token);
            }

            if (game.State.Phase != GamePhase.Bidding)
                return;

            _dealingActivePlayer = -1;
            if (game.CurrentBidSuit.HasValue)
            {
                var bidPlayer = game.CurrentBidPlayer;
                var bidSuit = game.CurrentBidSuit.Value;
                var bidCount = ResolveBidCardCount(game.CurrentBidSuit, game.CurrentBidPriority);
                ShowMessage($"发牌竞叫完成：{GetPlayerLabel(bidPlayer)}{FormatBidSummary(bidSuit, bidCount)}");
            }
            else if (lastBidInfo != null)
                ShowMessage($"发牌竞叫完成：{lastBidInfo}");
            else
                ShowMessage("发牌竞叫完成：无人亮主，自动定主");

            await AutoFinalizeBid(onlyWhenNoHumanOption: false);
        }
        catch (TaskCanceledException)
        {
            // Ignore canceled dealing animation when restarting game/round.
        }
        finally
        {
            var shouldContinueAiTurn = _pendingAiAutoPlayAfterDealing;
            _pendingAiAutoPlayAfterDealing = false;
            _isDealingBiddingAnimation = false;
            _dealingActivePlayer = -1;
            if (game != null)
                _visibleHandCount = Vm.PlayerHand.Count;

            await InvokeAsync(StateHasChanged);

            if (shouldContinueAiTurn)
                await ContinueAiTurnIfNeededAsync();
        }
    }

    private (List<Card> Cards, Dictionary<string, object?>? Detail) BuildBidAttemptFromVisibleCards(int playerIndex, List<Card> visibleCards, Rank levelRank, int roundIndex)
    {
        if (game == null || visibleCards.Count == 0)
            return (new List<Card>(), null);

        _bidPolicy ??= new BidPolicy(CurrentSeed + 12037);
        var decision = _bidPolicy.Decide(new BidPolicy.DecisionContext
        {
            PlayerIndex = playerIndex,
            DealerIndex = game.State.DealerIndex,
            LevelRank = levelRank,
            VisibleCards = new List<Card>(visibleCards),
            RoundIndex = roundIndex,
            CurrentBidPriority = game.CurrentBidPriority,
            CurrentBidPlayer = game.CurrentBidPlayer
        });
        var detail = decision.ToLogDetail();

        if (decision.AttemptCards.Count == 0)
            return (new List<Card>(), detail);

        if (game.CanBidTrumpEx(playerIndex, decision.AttemptCards).Success)
        {
            detail["bid_attempt_mode"] = "policy";
            detail["bid_attempt_count"] = decision.AttemptCards.Count;
            return (decision.AttemptCards, detail);
        }

        // 回退到单张再试一次，避免因优先级变化错过合法亮主。
        if (decision.AttemptCards.Count > 1)
        {
            var single = new List<Card> { decision.AttemptCards[0] };
            if (game.CanBidTrumpEx(playerIndex, single).Success)
            {
                detail["bid_attempt_mode"] = "fallback_single";
                detail["bid_attempt_count"] = 1;
                return (single, detail);
            }
        }

        return (new List<Card>(), detail);
    }

