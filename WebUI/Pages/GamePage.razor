        // 优先使用显示缓存（用于显示最后一家出牌）
        var trick = _displayTrick ?? game.CurrentTrick;
        var play = trick.FirstOrDefault(p => p.PlayerIndex == playerIndex);
        return play?.Cards ?? new List<Card>();
    }

