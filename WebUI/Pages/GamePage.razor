@page "/game"
@using System
@using System.Collections.Generic
@using System.Linq
@using System.Threading
@using TractorGame.Core.Models
@using TractorGame.Core.GameFlow
@using TractorGame.Core.AI
@using TractorGame.Core.AI.Bidding
@using TractorGame.Core.Logging
@using TractorGame.Core.Rules
@using WebUI.Application
@implements IDisposable
@inject NavigationManager Navigation
@inject UiMessageService MessageService
@inject UiAutomationService AutomationService
@inject AITurnService AITurnService
@inject GameSessionService GameSessionService
@inject PlayerActionService PlayerActionService
@inject UiTelemetryService UiTelemetryService
@inject UiTestActionService UiTestActionService
@inject TurnPlayService TurnPlayService
@inject RuleAIOptionsProvider RuleAIOptionsProvider
@inject AIDecisionLoggerFactory AIDecisionLoggerFactory
@inject AIRuntimeSessionService AIRuntimeSessionService
@inject IJSRuntime JS

<div class="game-container">
    <!-- 左上角信息栏 -->
    <div class="info-panel">
        <div class="settings-btn" data-testid="btn-settings" @onclick="ToggleSettings">⚙️</div>
        <div class="team-info">
            <div class="team-row">
                <span class="team-cell team-name">我方</span>
                <span class="team-cell team-level">@Vm.OurLevel</span>
                <span class="team-cell team-trump trump-suit @GetOurTrumpSuitColorClass()">@GetOurTeamTrumpText()</span>
                <span class="team-cell team-score-label">抓分</span>
            </div>
            <div class="team-row">
                <span class="team-cell team-name">对方</span>
                <span class="team-cell team-level">@Vm.TheirLevel</span>
                <span class="team-cell team-trump trump-suit @GetTheirTrumpSuitColorClass()">@GetTheirTeamTrumpText()</span>
                <span class="team-cell team-score">@Vm.DefenderScore</span>
            </div>
        </div>
        <div class="trick-uid-panel" data-testid="trick-uid-panel">
            <div class="trick-uid-label">墩UID</div>
            <div class="trick-uid-value" title="@GetDisplayedTrickUid()">@GetDisplayedTrickUidOrPlaceholder()</div>
            <button class="trick-uid-copy" data-testid="btn-copy-trick-uid" @onclick="CopyDisplayedTrickUid">复制</button>
        </div>
    </div>

    @if (_isDealingBiddingAnimation)
    {
        <div class="deal-rhythm-panel" data-testid="deal-rhythm-panel">
            <div class="deal-rhythm-title">发牌竞叫中</div>
            <div class="deal-rhythm-row">第 @_dealingRound / 25 轮 · @GetPlayerLabel(_dealingActivePlayer)摸牌</div>
            <div class="deal-rhythm-row bid">@_biddingAnimationText</div>
        </div>
    }

    <!-- 玩家位置 -->
    <div class="player-north">
        <div class="player-avatar @GetPlayerAvatarClass(2)">
            👤 北 @GetPlayerDealProgress(2)
            @if (IsDealerPlayer(2))
            {
                <span class="dealer-badge">庄</span>
            }
        </div>
    </div>

    <div class="player-west">
        <div class="player-avatar @GetPlayerAvatarClass(3)">
            👤 西 @GetPlayerDealProgress(3)
            @if (IsDealerPlayer(3))
            {
                <span class="dealer-badge">庄</span>
            }
        </div>
    </div>

    <div class="player-east">
        <div class="player-avatar @GetPlayerAvatarClass(1)">
            👤 东 @GetPlayerDealProgress(1)
            @if (IsDealerPlayer(1))
            {
                <span class="dealer-badge">庄</span>
            }
        </div>
    </div>

    <div class="player-south">
        <div class="player-avatar @GetPlayerAvatarClass(0)">
            👤 南 @GetPlayerDealProgress(0)
            @if (IsDealerPlayer(0))
            {
                <span class="dealer-badge">庄</span>
            }
        </div>
    </div>

    <!-- 出牌显示区 -->
    <div class="play-area" data-testid="play-area">
        @if (game != null && (_historyTrick != null || _displayTrick != null || game.CurrentTrick.Count > 0))
        {
            <!-- 北玩家出牌 -->
            <div class="played-cards-north">
                @foreach (var card in GetPlayedCards(2))
                {
                    <div class="played-card-shell @GetCardSizeClass(GetPlayedCards(2).Count)">
                        <img src="@GetCardImage(card)" class="played-card-face" data-testid="played-card" alt="@card" />
                    </div>
                }
            </div>

            <!-- 中间行：西和东玩家出牌 -->
            <div class="played-cards-middle-row">
                <!-- 西玩家出牌（左对齐） -->
                <div class="played-cards-west">
                    @foreach (var card in GetPlayedCards(3))
                    {
                        <div class="played-card-shell @GetCardSizeClass(GetPlayedCards(3).Count)">
                            <img src="@GetCardImage(card)" class="played-card-face" data-testid="played-card" alt="@card" />
                        </div>
                    }
                </div>

                <!-- 东玩家出牌（右对齐） -->
                <div class="played-cards-east">
                    @foreach (var card in GetPlayedCards(1))
                    {
                        <div class="played-card-shell @GetCardSizeClass(GetPlayedCards(1).Count)">
                            <img src="@GetCardImage(card)" class="played-card-face" data-testid="played-card" alt="@card" />
                        </div>
                    }
                </div>
            </div>

            <!-- 南玩家出牌 -->
            <div class="played-cards-south">
                @foreach (var card in GetPlayedCards(0))
                {
                    <div class="played-card-shell @GetCardSizeClass(GetPlayedCards(0).Count)">
                        <img src="@GetCardImage(card)" class="played-card-face" data-testid="played-card" alt="@card" />
                    </div>
                }
            </div>
        }
    </div>

    <!-- 亮牌框（仅发牌阶段显示） -->
    @if (Vm.ShowBiddingPanel)
    {
        <div class="bidding-panel" data-testid="bidding-panel">
            <button class="suit-btn @(CanBid(Suit.Joker) ? "active" : "")" data-testid="bid-joker" @onclick="() => BidTrump(Suit.Joker)">🃏</button>
            <button class="suit-btn @(CanBid(Suit.Spade) ? "active" : "")" data-testid="bid-spade" @onclick="() => BidTrump(Suit.Spade)">♠</button>
            <button class="suit-btn @(CanBid(Suit.Heart) ? "active" : "")" data-testid="bid-heart" @onclick="() => BidTrump(Suit.Heart)">♥</button>
            <button class="suit-btn @(CanBid(Suit.Club) ? "active" : "")" data-testid="bid-club" @onclick="() => BidTrump(Suit.Club)">♣</button>
            <button class="suit-btn @(CanBid(Suit.Diamond) ? "active" : "")" data-testid="bid-diamond" @onclick="() => BidTrump(Suit.Diamond)">♦</button>
            <button class="suit-btn bid-auto-btn" data-testid="bid-auto" @onclick="AutoFinalizeBidFromButton">自动定主</button>
        </div>
    }

    <!-- 手牌区 -->
    <div class="hand-area" data-testid="hand-area">
        @foreach (var (card, index) in GetVisibleHandCards().Select((c, i) => (c, i)))
        {
            <div class="hand-card-shell @(Vm.SelectedCardIndices.Contains(index) ? "selected" : "")"
                 data-testid="hand-card"
                 data-card-index="@index"
                 data-card-key="@($"{card.Suit}-{card.Rank}")"
                 @onclick="() => ToggleCardSelection(index)">
                <img src="@GetCardImage(card)"
                     class="hand-card"
                     alt="@card" />
            </div>
        }
        @if (_isDealingBiddingAnimation)
        {
            @for (var i = GetVisibleHandCards().Count; i < 25; i++)
            {
                <div class="hand-card-back" data-testid="hand-card-back"></div>
            }
        }
    </div>

    @if (_showBottomPreview && _bottomPreviewCards.Count > 0)
    {
        <div class="bottom-preview-panel" data-testid="bottom-preview-panel">
            <div class="bottom-preview-title">@_bottomPreviewTitle</div>
            <div class="bottom-preview-cards">
                @foreach (var card in _bottomPreviewCards)
                {
                    <img src="@GetCardImage(card)" class="bottom-preview-card" data-testid="bottom-preview-card" alt="@card" />
                }
            </div>
        </div>
    }

    <!-- 操作按钮 -->
    <div class="action-buttons">
        <button class="btn btn-play" data-testid="btn-play" @onclick="PlayCards" disabled="@(!CanPlay)">出牌</button>
        @if (Vm.ShowBuryButton)
        {
            <button class="btn btn-bury" data-testid="btn-bury" @onclick="BuryCards">扣底</button>
        }
        @if (Vm.ShowViewBottomButton)
        {
            <button class="btn btn-view" data-testid="btn-view-bottom" @onclick="ViewBottom">查看底牌</button>
        }
        <button class="btn btn-history" data-testid="btn-history" @onclick="ViewLastTrick">上一轮牌</button>
        @if (game?.State.Phase == GamePhase.Finished && ShowNextRoundButton)
        {
            <button class="btn btn-play" data-testid="btn-next-round" @onclick="StartNextRoundNow">下一局</button>
        }
    </div>

    @if (IsUiTestMode)
    {
        <div style="position:absolute; left:-9999px; top:-9999px;">
            <button data-testid="btn-test-auto-select" @onclick="AutoSelectForTest">test-auto-select</button>
            <button data-testid="btn-test-auto-bury-select" @onclick="AutoSelectBuryForTest">test-auto-bury-select</button>
            <button data-testid="btn-test-force-finalize-bid" @onclick="ForceFinalizeBidForTest">test-force-finalize-bid</button>
        </div>

        <div data-testid="test-state"
             data-phase="@GetPhaseName()"
             data-current-player="@GetCurrentPlayer()"
             data-defender-score="@Vm.DefenderScore"
             data-selected-count="@Vm.SelectedCardIndices.Count"
             data-hand-count="@Vm.PlayerHand.Count"
             data-trick-count="@_trickNumber"
             style="display:none"></div>
    }

    <!-- 提示信息 -->
    @if (!string.IsNullOrEmpty(MessageService.CurrentMessage))
    {
        <div class="message-toast" data-testid="message-toast">@MessageService.CurrentMessage</div>
    }
</div>

@code {
    // 游戏状态
    private Game? game;
    private readonly GamePageViewModel Vm = new();
    private List<TrickPlay>? _displayTrick = null; // 用于显示最后一家出牌
    private List<TrickPlay>? _historyTrick = null; // 用于显示上一墩
    private int _historyTrickNo = 0;
    private bool _showBottomPreview;
    private List<Card> _bottomPreviewCards = new();
    private string _bottomPreviewTitle = "底牌预览";
    private CancellationTokenSource? _bottomPreviewAutoCloseCts;
    private const int BottomPreviewAutoCloseDelayMs = 1800;
    private bool CanPlay => Vm.SelectedCardIndices.Count > 0 && game?.State.Phase == GamePhase.Playing && game?.State.CurrentPlayer == 0;

    // 自动化测试状态
    private bool IsUiTestMode = false;
    private int? ForcedSeed;
    private int CurrentSeed;
    private int _trickNumber = 0;
    private int _actionCounter = 0;
    private int _campaignDealerIndex = 0;
    private Rank _ourTeamLevelRank = Rank.Two;
    private Rank _theirTeamLevelRank = Rank.Two;
    private readonly LevelManager _levelManager = new();
    private bool ShowNextRoundButton = false;
    private bool _roundTransitioning = false;
    private CancellationTokenSource? _roundTransitionCts;
    private CancellationTokenSource? _dealingFlowCts;
    private bool _isDealingBiddingAnimation;
    private int _dealingRound;
    private int _dealingActivePlayer = -1;
    private int _visibleHandCount = 25;
    private string _biddingAnimationText = string.Empty;
    private int _lastBidPlayer = -1;
    private bool _pendingAiAutoPlayAfterDealing;
    private bool _isFirstCampaignRound = true;
    private BidPolicy? _bidPolicy;

    protected override void OnInitialized()
    {
        MessageService.Changed += OnMessageChanged;
        MessageService.Clear();
        ParseAutomationOptions();
        StartNewGame();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && IsUiTestMode)
            await InitializeTestHooksAsync();
    }

    public void Dispose()
    {
        MessageService.Changed -= OnMessageChanged;
        _bottomPreviewAutoCloseCts?.Cancel();
        _bottomPreviewAutoCloseCts?.Dispose();
        _roundTransitionCts?.Cancel();
        _roundTransitionCts?.Dispose();
        _dealingFlowCts?.Cancel();
        _dealingFlowCts?.Dispose();
    }

    private void OnMessageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void ParseAutomationOptions()
    {
        AutomationService.ConfigureFromUri(Navigation.Uri);
        IsUiTestMode = AutomationService.IsEnabled;
        ForcedSeed = AutomationService.ForcedSeed;
    }

    private void StartNewGame()
    {
        _roundTransitionCts?.Cancel();
        _roundTransitionCts?.Dispose();
        _roundTransitionCts = null;
        _dealingFlowCts?.Cancel();
        _dealingFlowCts?.Dispose();
        _dealingFlowCts = new CancellationTokenSource();
        ShowNextRoundButton = false;
        _roundTransitioning = false;
        _isDealingBiddingAnimation = false;
        _dealingRound = 0;
        _dealingActivePlayer = -1;
        _visibleHandCount = 0;
        _biddingAnimationText = string.Empty;
        _lastBidPlayer = -1;
        _pendingAiAutoPlayAfterDealing = false;

        var roundLevel = GetCurrentDealerTeamLevel();
        var session = GameSessionService.StartNewGame(
            ForcedSeed,
            _campaignDealerIndex,
            roundLevel,
            bidWinnerBecomesDealer: _isFirstCampaignRound);
        game = session.Game;
        CurrentSeed = session.Seed;
        _isFirstCampaignRound = false;
        _bidPolicy = new BidPolicy(CurrentSeed + 12037);
        _trickNumber = 0;
        _actionCounter = 0;
        _displayTrick = null;
        ClearHistoryPreview();
        ClearBottomPreview();
        Vm.SelectedCardIndices.Clear();
        UpdateUI();
        ShowMessage("开始发牌，进入竞叫阶段...");
        _ = RunDealingBiddingFlowAsync();
    }

    private async Task InitializeTestHooksAsync()
    {
        await AutomationService.InitializeTestHooksAsync(game, CurrentSeed);
    }

    private async Task PushTestEventAsync(object payload)
    {
        await AutomationService.PushEventAsync(payload, game, GetNormalizedPhase());
    }

    private string GetPhaseName()
    {
        return game?.State.Phase.ToString() ?? "None";
    }

    private int GetCurrentPlayer()
    {
        return game?.State.CurrentPlayer ?? -1;
    }

    private void UpdateUI()
    {
        if (game == null)
            return;

        GameSessionService.UpdateViewModel(game, Vm);
        Vm.OurLevel = FormatLevel(_ourTeamLevelRank);
        Vm.TheirLevel = FormatLevel(_theirTeamLevelRank);
        if (!_isDealingBiddingAnimation || game.State.Phase != GamePhase.Bidding)
        {
            _visibleHandCount = Vm.PlayerHand.Count;
        }
    }

    private string GetCardImage(Card card)
    {
        // 映射到实际的图片文件名
        if (card.Rank == Rank.BigJoker)
            return "assets/playingcardshl/red_joker.png";
        if (card.Rank == Rank.SmallJoker)
            return "assets/playingcardshl/black_joker.png";

        string rank = card.Rank switch
        {
            Rank.Ace => "ace",
            Rank.Two => "2",
            Rank.Three => "3",
            Rank.Four => "4",
            Rank.Five => "5",
            Rank.Six => "6",
            Rank.Seven => "7",
            Rank.Eight => "8",
            Rank.Nine => "9",
            Rank.Ten => "10",
            Rank.Jack => "jack",
            Rank.Queen => "queen",
            Rank.King => "king",
            _ => "2"
        };

        string suit = card.Suit switch
        {
            Suit.Spade => "spades",
            Suit.Heart => "hearts",
            Suit.Club => "clubs",
            Suit.Diamond => "diamonds",
            _ => "spades"
        };

        return $"assets/playingcardshl/{rank}_of_{suit}.png";
    }

    private void ToggleCardSelection(int index)
    {
        if (_isDealingBiddingAnimation)
            return;

        if (index < 0 || index >= Vm.PlayerHand.Count)
            return;

        bool deselect = Vm.SelectedCardIndices.Contains(index);
        PlayerActionService.ToggleSelection(Vm, index);
        UiTelemetryService.LogCardSelect(game, GetNormalizedPhase(), Vm.PlayerHand[index], Vm.SelectedCardIndices.Count, deselect ? "deselect" : "select");
    }

    private List<Card> GetSelectedCards()
    {
        return PlayerActionService.GetSelectedCards(Vm);
    }

    private GameConfig BuildCurrentConfig()
    {
        if (game == null)
            return new GameConfig { LevelRank = Rank.Two, TrumpSuit = Suit.Spade };

        return GameSessionService.BuildCurrentConfig(game);
    }

    private AIRole GetRoleForPlayer(int playerIndex)
    {
        if (game == null)
            return AIRole.Opponent;

        return GameSessionService.GetRoleForPlayer(game, playerIndex);
    }

    private List<Card> GetCurrentWinningCards()
    {
        if (game == null)
            return new List<Card>();

        return GameSessionService.GetCurrentWinningCards(game);
    }

    private bool IsPartnerWinning(int playerIndex)
    {
        if (game == null)
            return false;

        return GameSessionService.IsPartnerWinning(game, playerIndex);
    }

    private object[] SerializeCards(IEnumerable<Card> cards)
    {
        return cards.Select(c => new
        {
            suit = c.Suit.ToString(),
            rank = c.Rank.ToString(),
            score = c.Score,
            text = c.ToString()
        }).Cast<object>().ToArray();
    }

    private object[] SerializePlays(IEnumerable<TrickPlay> plays)
    {
        return plays.Select(p => new
        {
            playerIndex = p.PlayerIndex,
            cards = SerializeCards(p.Cards)
        }).Cast<object>().ToArray();
    }

    private async Task<bool> PlayCardsAndTraceAsync(int playerIndex, List<Card> cards, string actor)
    {
        if (game == null)
            return false;

        return await TurnPlayService.PlayAndTraceAsync(
            game,
            playerIndex,
            cards,
            actor,
            () => ++_actionCounter,
            () => _trickNumber,
            value => _trickNumber = value,
            trick => _displayTrick = trick,
            SerializeCards,
            SerializePlays,
            PushTestEventAsync,
            async () =>
            {
                UpdateUI();
                await InvokeAsync(StateHasChanged);
            });
    }

    private async Task PlayCards()
    {
        if (game == null || Vm.SelectedCardIndices.Count == 0)
            return;

        ClearHistoryPreview();
        ClearBottomPreview();
        UiTelemetryService.LogActionClick(game, GetNormalizedPhase(), "btn-play", CanPlay);
        var selected = GetSelectedCards();
        bool success = await PlayCardsAndTraceAsync(0, selected, "human");
        if (!success)
        {
            ShowMessage("出牌不合法");
            return;
        }

        Vm.SelectedCardIndices.Clear();
        UpdateUI();

        if (game.State.Phase == GamePhase.Finished)
        {
            await HandleGameFinishedAsync();
            return;
        }

        // 如果是AI的回合，自动出牌
        if (game.State.CurrentPlayer != 0 && game.State.Phase == GamePhase.Playing)
        {
            await Task.Delay(300);
            await AIPlay();
        }
    }

    private async Task AIPlay()
    {
        if (game == null)
            return;

        ClearHistoryPreview();
        await AITurnService.RunUntilHumanTurnAsync(
            game,
            CurrentSeed,
            () => _actionCounter,
            BuildCurrentConfig,
            GetRoleForPlayer,
            GetCurrentWinningCards,
            IsPartnerWinning,
            PlayCardsAndTraceAsync,
            PushTestEventAsync,
            ShowMessage);

        // 检查游戏是否结束
        if (game.State.Phase == GamePhase.Finished)
            await HandleGameFinishedAsync();
    }

    private async Task HandleGameFinishedAsync()
    {
        if (game == null || game.State.Phase != GamePhase.Finished || _roundTransitioning)
            return;

        _roundTransitioning = true;
        ShowNextRoundButton = true;

        int currentDealer = game.State.DealerIndex;
        var dealerTeamIsOurSide = currentDealer % 2 == 0;
        var dealerTeamLevel = dealerTeamIsOurSide ? _ourTeamLevelRank : _theirTeamLevelRank;
        var result = _levelManager.DetermineLevelChange(game.State.DefenderScore, dealerTeamLevel);
        int nextDealer = _levelManager.DetermineNextDealerIndex(currentDealer, result.Winner);

        if (result.Winner == "庄家")
        {
            if (dealerTeamIsOurSide)
                _ourTeamLevelRank = result.NextLevel;
            else
                _theirTeamLevelRank = result.NextLevel;
        }
        else
        {
            if (dealerTeamIsOurSide)
                _theirTeamLevelRank = result.NextLevel;
            else
                _ourTeamLevelRank = result.NextLevel;
        }

        _campaignDealerIndex = nextDealer;

        ShowMessage($"本局结束！闲家得分：{game.State.DefenderScore}。下一局庄家：{GetPlayerLabel(_campaignDealerIndex)}，打{FormatLevel(GetCurrentDealerTeamLevel())}。");
        await InvokeAsync(StateHasChanged);

        if (IsUiTestMode)
        {
            _roundTransitioning = false;
            return;
        }

        _roundTransitionCts?.Cancel();
        _roundTransitionCts?.Dispose();
        _roundTransitionCts = new CancellationTokenSource();
        var token = _roundTransitionCts.Token;

        try
        {
            await Task.Delay(2000, token);
            if (token.IsCancellationRequested)
                return;

            StartNewGame();
        }
        catch (TaskCanceledException)
        {
            // ignore
        }
        finally
        {
            _roundTransitioning = false;
        }
    }

    private Task StartNextRoundNow()
    {
        StartNewGame();
        return Task.CompletedTask;
    }

    private async Task BuryCards()
    {
        UiTelemetryService.LogActionClick(game, GetNormalizedPhase(), "btn-bury", game != null && Vm.SelectedCardIndices.Count == 8);
        if (game == null || Vm.SelectedCardIndices.Count != 8)
        {
            ShowMessage("请选择8张牌扣底");
            return;
        }

        var cardsToBury = GetSelectedCards();
        bool success = game.BuryBottom(cardsToBury);
        if (!success)
        {
            ShowMessage("扣底失败");
            return;
        }

        await PushTestEventAsync(new
        {
            type = "bury_bottom",
            playerIndex = 0,
            cards = SerializeCards(cardsToBury)
        });

        Vm.SelectedCardIndices.Clear();
        UpdateUI();
        ShowBottomPreview(game.State.BuriedCards, "底牌（已扣底）");
        ShowMessage("扣底成功，开始出牌");
        await InvokeAsync(StateHasChanged);
        _ = AutoCloseBottomPreviewAfterDelayAsync();
    }

    private Task ViewBottom()
    {
        UiTelemetryService.LogActionClick(game, GetNormalizedPhase(), "btn-view-bottom", true);

        if (game == null)
        {
            ShowMessage("当前无对局");
            return Task.CompletedTask;
        }

        if (_showBottomPreview)
        {
            ClearBottomPreview();
            ShowMessage("已收起底牌");
            StateHasChanged();
            return Task.CompletedTask;
        }

        if (game.State.Phase == GamePhase.Burying)
        {
            var bottomCards = game.BottomCardsSnapshot;
            if (bottomCards.Count == 0)
            {
                ShowMessage("暂无底牌可查看");
                return Task.CompletedTask;
            }

            ShowBottomPreview(bottomCards, "底牌（原始8张）");
            ShowMessage("正在查看底牌");
            StateHasChanged();
            return Task.CompletedTask;
        }

        if (game.State.BuriedCards.Count == 0)
        {
            ShowMessage("暂无底牌可查看");
            return Task.CompletedTask;
        }

        ShowBottomPreview(game.State.BuriedCards, "底牌（已扣底）");
        ShowMessage("正在查看底牌");
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task ViewLastTrick()
    {
        UiTelemetryService.LogActionClick(game, GetNormalizedPhase(), "btn-history", true);

        if (game == null)
        {
            ShowMessage("当前无对局");
            return Task.CompletedTask;
        }

        var lastTrick = game.LastCompletedTrick;
        if (lastTrick.Count == 0)
        {
            ShowMessage("暂无上一轮牌");
            return Task.CompletedTask;
        }

        if (_historyTrick != null && _historyTrickNo == game.LastCompletedTrickNo)
        {
            ClearHistoryPreview();
            ShowMessage("已返回当前出牌");
            StateHasChanged();
            return Task.CompletedTask;
        }

        _displayTrick = null;
        _historyTrick = CloneTrick(lastTrick);
        _historyTrickNo = game.LastCompletedTrickNo;
        ShowMessage($"正在查看第{_historyTrickNo}墩");
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task BidTrump(Suit suit)
    {
        UiTelemetryService.LogActionClick(game, GetNormalizedPhase(), $"bid-{suit.ToString().ToLowerInvariant()}", CanBid(suit));
        if (game == null || game.State.Phase != GamePhase.Bidding)
            return;

        var levelCards = PlayerActionService.GetBidLevelCards(game, Vm, suit);

        if (levelCards.Count == 0)
        {
            ShowMessage("没有该花色的级牌");
            return;
        }

        var bidCards = BuildBestBidAttempt(game, levelCards);
        if (bidCards.Count == 0)
        {
            var fallback = game.CanBidTrumpEx(0, new List<Card> { levelCards[0] });
            ShowMessage(GetBidFailureMessage(game, fallback.ReasonCode));
            return;
        }

        var bidResult = game.BidTrumpEx(0, bidCards);
        if (!bidResult.Success)
        {
            ShowMessage(GetBidFailureMessage(game, bidResult.ReasonCode));
            return;
        }

        _lastBidPlayer = 0;
        UpdateUI();
        StateHasChanged();
        await PushTestEventAsync(new
        {
            type = "bid_trump",
            playerIndex = 0,
            suit = suit.ToString(),
            cards = SerializeCards(bidCards)
        });

        ShowMessage(suit == Suit.Joker
            ? "反无主成功"
            : $"亮主成功：{GameSessionService.GetSuitSymbol(suit)}");

        // 延迟后确定主花色并进入扣底阶段
        await Task.Delay(350);

        var finalizeResult = game.FinalizeTrumpEx(suit);
        if (!finalizeResult.Success)
        {
            if (finalizeResult.ReasonCode == ReasonCodes.DealingNotComplete)
                ShowMessage("亮主成功，待发牌结束后定主");
            else
                ShowMessage($"定主失败：{finalizeResult.ReasonCode}");
            UpdateUI();
            return;
        }

        await PushTestEventAsync(new
        {
            type = "trump_finalized",
            trumpSuit = suit.ToString(),
            dealerIndex = game.State.DealerIndex
        });

        UpdateUI();

        if (game.State.DealerIndex == 0)
        {
            ShowMessage("请扣底（选择8张牌）");
        }
        else
        {
            ShowMessage("庄家扣底中...");
            await AIBuryBottom();
        }
    }

